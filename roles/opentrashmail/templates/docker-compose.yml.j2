# Managed by Ansible — do not edit manually.
services:
  opentrashmail:
    image: "{{ opentrashmail_image }}:{{ opentrashmail_image_tag }}"
    container_name: opentrashmail
    restart: unless-stopped
    ports:
      - "{{ opentrashmail_smtp_port }}:25"
      - "{{ opentrashmail_http_port }}:80"
    volumes:
      - "{{ opentrashmail_data_mount }}/mail:/var/mail"
      - "{{ opentrashmail_data_mount }}/data:/var/www/opentrashmail/data"
      - "{{ opentrashmail_data_mount }}/logs:/var/www/opentrashmail/logs"
    environment:
      - "DOMAINS={{ opentrashmail_domain }}"
      - "URL={{ opentrashmail_url }}"
      - "DISCARD_UNKNOWN={{ opentrashmail_discard_unknown }}"
      - "SHOW_ACCOUNT_LIST={{ opentrashmail_show_account_list }}"
      - "ADMIN={{ opentrashmail_admin }}"
